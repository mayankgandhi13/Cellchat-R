cat('useDynLib(cellchatr, .registration = TRUE)\n',
file = "NAMESPACE", append = TRUE)
library(cellchatr)
# Simulate small expression matrix: 5 genes x 6 cells
counts <- matrix(c(
0,0,0,5,6,7,   # gene 1 - high in type B
1,1,1,1,1,1,   # gene 2 - flat, not DE
3,4,5,0,0,0,   # gene 3 - high in type A
0,0,0,0,0,0,   # gene 4 - all zeros
2,3,4,5,6,7    # gene 5 - generally high
), nrow = 5, byrow = TRUE)
labels     <- c("A","A","A","B","B","B")
gene_names <- c("TGFB1","GAPDH","COL1A1","MYC","VEGFA")
rust_wilcoxon_filter(counts, labels, gene_names, pval_threshold = 0.05)
rextendr::document()
readLines("NAMESPACE")
library(cellchatr)
counts <- matrix(c(
0,0,0,5,6,7,
1,1,1,1,1,1,
3,4,5,0,0,0,
0,0,0,0,0,0,
2,3,4,5,6,7
), nrow = 5, byrow = TRUE)
labels     <- c("A","A","A","B","B","B")
gene_names <- c("TGFB1","GAPDH","COL1A1","MYC","VEGFA")
rust_wilcoxon_filter(counts, labels, gene_names, pval_threshold = 0.05)
# Test with stricter threshold
rust_wilcoxon_filter(counts, labels, gene_names, pval_threshold = 0.01)
# And even stricter
rust_wilcoxon_filter(counts, labels, gene_names, pval_threshold = 0.001)
set.seed(42)
n_cells <- 100
n_genes <- 50
# 50 cells type A, 50 cells type B
labels <- c(rep("A", 50), rep("B", 50))
gene_names <- paste0("GENE", 1:n_genes)
# Make first 10 genes highly overexpressed in type B
counts <- matrix(rnorm(n_genes * n_cells, mean = 1, sd = 1),
nrow = n_genes)
counts[1:10, 51:100] <- counts[1:10, 51:100] + 5  # boost genes 1-10 in type B
result <- rust_wilcoxon_filter(counts, labels, gene_names, pval_threshold = 0.05)
result
rextendr::document()
library(cellchatr)
# Simulate overexpressed genes from previous step
overexpressed <- c("TGFB1", "COL1A1", "VEGFA")
# Simulate a small CellChatDB
lr_ligands   <- c("TGFB1",       "VEGFA",    "MYC",    "COL1A1", "EGFR")
lr_receptors <- c("TGFBR1",      "FLT1",     "MYCBP",  "CD44",   "EGF")
lr_names     <- c("TGFB1_TGFBR1","VEGFA_FLT1","MYC_MYCBP","COL1A1_CD44","EGFR_EGF")
rust_match_lr_pairs(overexpressed, lr_ligands, lr_receptors, lr_names)
